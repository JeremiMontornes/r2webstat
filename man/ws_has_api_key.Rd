\name{ws_has_api_key}
\alias{ws_has_api_key}
\title{Check whether a Webstat API key is available}
\usage{ws_has_api_key()}
\value{`TRUE` when `WEBSTAT_API_KEY` is set for the current R session.}
\description{Check whether a Webstat API key is available through the `WEBSTAT_API_KEY` environment variable.}
